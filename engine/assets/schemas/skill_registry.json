{
  "title": "SkillRegistry",
  "description": "Master registry of valid skill names, level caps, and stat bonuses.",
  "type": "object",
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Unique skill identifier" },
          "max_level": { "type": "number", "default": 100, "description": "Level cap for this skill" },
          "base_xp_per_action": { "type": "number", "default": 10, "description": "Base XP granted per job completion or action" },
          "derived_stat_bonus": {
            "type": "object",
            "additionalProperties": { "type": "number" },
            "default": {},
            "description": "Per-level stat bonus: {stat_name: bonus_per_level}"
          }
        },
        "required": ["name"]
      }
    }
  },
  "required": ["skills"],
