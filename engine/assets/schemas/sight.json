{
  "title": "Sight",
  "description": "Defines an entity's field-of-view capabilities.",
  "type": "object",
  "properties": {
    "range": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 8,
      "description": "Maximum vision range in cells"
    },
    "radius": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 8,
      "description": "Vision radius (identical to range for default case)"
    }
  },
  "required": ["range"],
  "modes": ["colony", "roguelike", "simulation"]
}
